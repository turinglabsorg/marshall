{
  "name": "marshall",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "P2P-first consumer AI compute network prototype",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dataset:marshall:build": "python3 training/build_marshall_instruction_dataset.py --output-dir .marshall/datasets/marshall-instructions",
    "dataset:marshall:check": "python3 training/build_marshall_instruction_dataset.py --output-dir .marshall/datasets/marshall-instructions --check",
    "dataset:ag-news:build": "python3 training/build_ag_news_dataset.py --output-dir .marshall/datasets/ag-news",
    "dataset:ag-news:check": "python3 training/build_ag_news_dataset.py --output-dir .marshall/datasets/ag-news --check",
    "dataset:ag-news:micro:build": "python3 training/build_ag_news_dataset.py --output-dir .marshall/datasets/ag-news-micro --train-size ${MARSHALL_MICRO_TRAIN_SIZE:-8192} --valid-size ${MARSHALL_MICRO_VALID_SIZE:-1024} --test-size ${MARSHALL_MICRO_TEST_SIZE:-400} --eval-size ${MARSHALL_MICRO_EVAL_SIZE:-200} --shard-count ${MARSHALL_MICRO_SHARDS:-128}",
    "dataset:ag-news:micro:check": "python3 training/build_ag_news_dataset.py --output-dir .marshall/datasets/ag-news-micro --shard-count ${MARSHALL_MICRO_SHARDS:-128} --check",
    "eval:jobs": "tsx src/evaluation-jobs-cli.ts",
    "validation:jobs": "tsx src/validation-jobs-cli.ts",
    "leaderboard:adapters": "tsx src/leaderboard-cli.ts",
    "model:package": "tsx src/model-package-cli.ts",
    "model:query": "tsx src/model-query-cli.ts",
    "e2e:ag-news": "tsx src/e2e-ag-news-cli.ts",
    "e2e:ag-news:compiled": "npm run build && node dist/src/e2e-ag-news-cli.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:mlx:smoke": "${MARSHALL_PYTHON:-python3} training/mlx_linear_smoke.py",
    "test:mlx:lora": "${MARSHALL_PYTHON:-python3} training/mlx_lora_smoke.py --dataset-dir .marshall/datasets/marshall-instructions --output-dir .marshall/manual-lora --job-id job_manual_lora --run-id run_manual_lora --round-id round_001 --iters ${MARSHALL_ITERS:-20}",
    "test:mlx:lora:eval": "${MARSHALL_PYTHON:-python3} training/mlx_lora_eval.py --eval-file .marshall/datasets/marshall-instructions/eval.jsonl --output-dir .marshall/manual-lora-eval --adapter-path .marshall/manual-lora/adapters --max-examples ${MARSHALL_EVAL_EXAMPLES:-8}",
    "test:mlx:ag-news:eval": "${MARSHALL_PYTHON:-python3} training/mlx_ag_news_eval.py --eval-file .marshall/datasets/ag-news/eval.jsonl --output-dir .marshall/ag-news-eval --max-examples ${MARSHALL_EVAL_EXAMPLES:-80}",
    "test:watch": "vitest",
    "control:start": "tsx src/control-cli.ts",
    "worker:start": "tsx src/worker-cli.ts",
    "worker:pool": "tsx src/worker-pool-cli.ts",
    "control:start:compiled": "npm run build && node dist/src/control-cli.js",
    "worker:start:compiled": "npm run build && node dist/src/worker-cli.js",
    "worker:pool:compiled": "npm run build && node dist/src/worker-pool-cli.js",
    "demo": "tsx src/demo.ts",
    "demo:compiled": "npm run build && node dist/src/demo.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/bootstrap": "^12.0.25",
    "@libp2p/identify": "^4.1.8",
    "@libp2p/interface": "^3.2.4",
    "@libp2p/mdns": "^12.0.25",
    "@libp2p/ping": "^3.1.7",
    "@libp2p/tcp": "^11.0.22",
    "@multiformats/multiaddr": "^13.0.3",
    "it-length-prefixed": "^11.0.1",
    "it-pipe": "^3.0.1",
    "libp2p": "^3.3.4",
    "uint8arrays": "^6.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
