{
  "name": "marshall",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "P2P-first consumer AI compute network prototype",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dataset:marshall:build": "python3 training/build_marshall_instruction_dataset.py --output-dir examples/datasets/marshall-instructions",
    "dataset:marshall:check": "python3 training/build_marshall_instruction_dataset.py --output-dir examples/datasets/marshall-instructions --check",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:mlx:smoke": "${MARSHALL_PYTHON:-python3} training/mlx_linear_smoke.py",
    "test:mlx:lora": "${MARSHALL_PYTHON:-python3} training/mlx_lora_smoke.py --dataset-dir examples/datasets/marshall-instructions --output-dir .marshall/manual-lora --job-id job_manual_lora --run-id run_manual_lora --round-id round_001 --iters ${MARSHALL_ITERS:-20}",
    "test:mlx:lora:eval": "${MARSHALL_PYTHON:-python3} training/mlx_lora_eval.py --eval-file examples/datasets/marshall-instructions/eval.jsonl --output-dir .marshall/manual-lora-eval --adapter-path .marshall/manual-lora/adapters --max-examples ${MARSHALL_EVAL_EXAMPLES:-8}",
    "test:watch": "vitest",
    "control:start": "tsx src/control-cli.ts",
    "worker:start": "tsx src/worker-cli.ts",
    "control:start:compiled": "npm run build && node dist/src/control-cli.js",
    "worker:start:compiled": "npm run build && node dist/src/worker-cli.js",
    "demo": "tsx src/demo.ts",
    "demo:compiled": "npm run build && node dist/src/demo.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/bootstrap": "^12.0.25",
    "@libp2p/identify": "^4.1.8",
    "@libp2p/interface": "^3.2.4",
    "@libp2p/mdns": "^12.0.25",
    "@libp2p/ping": "^3.1.7",
    "@libp2p/tcp": "^11.0.22",
    "@multiformats/multiaddr": "^13.0.3",
    "it-length-prefixed": "^11.0.1",
    "it-pipe": "^3.0.1",
    "libp2p": "^3.3.4",
    "uint8arrays": "^6.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
