[Unit]
Description=Marshall coordinator
After=network-online.target marshall-redis.service
Wants=network-online.target
Requires=marshall-redis.service

[Service]
Type=simple
User=marshall
Group=marshall
EnvironmentFile=/etc/marshall/coordinator.env
EnvironmentFile=/etc/marshall/node.env
ExecStart=/opt/marshall/bin/marshall-coordinator
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
