marshall.training {
	encode zstd gzip

	handle_path /datasets/* {
		root * /var/lib/marshall/datasets
		file_server
	}

	handle /control.json {
		root * /var/lib/marshall/public
		file_server
	}

	handle /models/index.json {
		root * /var/lib/marshall/model-packages
		file_server
	}

	redir /chat /chat/ 308

	handle_path /chat/* {
		reverse_proxy 127.0.0.1:8787
	}

	reverse_proxy 127.0.0.1:8080
}

marshall.chat {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8787
}

:80 {
	reverse_proxy 127.0.0.1:8080
}
